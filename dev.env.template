NODE_ENV=dev
NODE_PORT=3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=hotel_db
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PW=
ADMIN_EMAIL=
APP_URL=http://localhost:9000
APP_NAME=hotelManagement
# 员工登录态 JWT 签名密钥；生产环境必填，dev/test 缺省时回落到 APP_NAME 派生值
JWT_SECRET=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=admin
EMAIL_PW=

# 自动账单任务
AUTO_BILL_ENABLED=true
AUTO_BILL_CRON=0 18 * * *
AUTO_BILL_TZ=Asia/Shanghai
AUTO_BILL_STATUS_WHITELIST=pending
AUTO_BILL_ALERT_EMAILS=peach19@foxmail.com

# OTA API
OTA_API_ENABLED=true
OTA_MEITUAN_KEY=meituan-demo-key
OTA_MEITUAN_SECRET=meituan-demo-secret
OTA_SIGN_SKEW_SECONDS=300
OTA_NONCE_TTL_SECONDS=600

# Plugin API（动态签名）
PLUGIN_API_KEY=plugin-demo-key
PLUGIN_API_SECRET=plugin-demo-secret
PLUGIN_SIGN_SKEW_SECONDS=300
PLUGIN_NONCE_TTL_SECONDS=600
