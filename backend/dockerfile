FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

FROM node:22-bookworm-slim AS runner
WORKDIR /app
COPY --from=builder /app/node_modules /app/node_modules
COPY --from=builder /app/package*.json /app/
COPY . .

ENV NODE_ENV=dev
ENV NODE_PORT=3000
ENV PORT=3000

HEALTHCHECK --interval=5s --timeout=3s --retries=10 CMD \
    node -e "require('http').get('http://localhost:3000/api/hup', r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"

CMD ["npm", "run", "dev"]