FROM node:22.20.0 AS builder

WORKDIR /app

# Copy package files first to leverage cache for dependencies
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

FROM node:22.20.0 AS runner

RUN mkdir -p /home/node/app/node_modules && chown -R node:node /home/node/app

WORKDIR /home/node/app

USER node

# Copy node_modules from builder stage
COPY --chown=node:node --from=builder /app/node_modules ./node_modules

# Copy package files to ensure dependencies info is available
COPY --chown=node:node package*.json ./

# Copy source code last since it changes most frequently
COPY --chown=node:node . .

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 CMD curl -f http://localhost:3000/api/hup || exit 1

CMD ["node", "server.js"]