FROM node:22.20.0 AS builder

WORKDIR /app

# Copy backend package files first to leverage cache for dependencies
COPY backend/package*.json ./

# Install dependencies in the container (not copying from host)
RUN npm install --omit=dev

FROM node:22.20.0 AS runner

RUN mkdir -p /home/node/app/node_modules && chown -R node:node /home/node/app

WORKDIR /home/node/app

USER node

# Copy node_modules from builder stage (built for Linux)
COPY --chown=node:node --from=builder /app/node_modules ./node_modules

# Copy backend package files
COPY --chown=node:node backend/package*.json ./

# Copy backend source code
COPY --chown=node:node backend/ ./

# Copy frontend dist (if exists) - create directory structure
RUN mkdir -p ./frontend_dist
COPY --chown=node:node frontend/dist/spa/ ./frontend_dist/

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 CMD curl -f http://localhost:3000/api/hup || exit 1

CMD ["node", "server.js"]
