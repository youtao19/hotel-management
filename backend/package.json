{
  "name": "hotel-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon server.js",
    "dev:test": "cross-env NODE_ENV=test node server.js",
    "start": "node server.js",
    "start:test": "cross-env NODE_ENV=test node server.js",
    "test": "dotenv --overload -e ../.env.test -- cross-env NODE_ENV=test jest --runInBand --rootDir=.",
    "test:watch": "dotenv --overload -e ../.env.test -- cross-env NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "dotenv --overload -e ../.env.test -- cross-env NODE_ENV=test jest --coverage --runInBand",
    "test:ci": "dotenv --overload -e ../.env.test -- cross-env NODE_ENV=test jest --runInBand --rootDir=.",
    "export-schema": "node scripts/exportSchema.js",
    "export-structure": "node scripts/exportStructure.js",
    "export-all": "node scripts/exportAll.js",
    "db:backup": "node scripts/exportAll.js",
    "db:init": "dotenv -e ../dev.env -- node -e \"require('./database/postgreDB/pg').initializeHotelDB()\"",
    "db:migrate": "node database/postgreDB/migrations/run-migrations.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^5.1.1",
    "connect-history-api-fallback": "^2.0.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^3.3.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.3",
    "pg": "^8.16.0",
    "rate-limiter-flexible": "^7.1.0",
    "redis": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bcryptjs": "^3.0.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  }
}
