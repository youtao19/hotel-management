{
    "name": "hotel-management-system",
    "version": "0.0.1",
    "description": "酒店管理系统",
    "productName": "酒店管理系统",
    "author": "youtao19 <wuyoutao19@gmail.com>",
    "private": true,
    "scripts": {
        "dev": "npm --workspace backend run dev",
        "start": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
        "build": "npm --workspace frontend run build",
        "test": "cross-env NODE_ENV=test jest --config ./jest.config.js",
        "test:watch": "cross-env NODE_ENV=test jest --config ./jest.config.js --watch",
        "export-schema": "npm --workspace backend run export-schema",
        "export-structure": "npm --workspace backend run export-structure",
        "export-all": "npm --workspace backend run export-all",
        "db:backup": "npm --workspace backend run db:backup",
        "db:init": "npm --workspace backend run db:init",
        "db:migrate": "npm --workspace backend run db:migrate"
    },
    "devDependencies": {
        "concurrently": "^8.2.0"
    },
    "workspaces": [
        "frontend",
        "backend"
    ],
    "engines": {
        "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
        "npm": ">= 6.13.4"
    }
}
